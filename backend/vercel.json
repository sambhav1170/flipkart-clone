{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["db/database.sqlite", "config/db.js", "db/schema.sql", "db/seed.sql", "routes/**/*.js", "middleware/**/*.js", "controllers/**/*.js"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
